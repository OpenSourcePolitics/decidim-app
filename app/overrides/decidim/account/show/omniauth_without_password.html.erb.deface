<!-- insert_before "erb[silent]:contains('elsif current_organization.sign_in_enabled?')" -->
  <% elsif current_organization.enabled_omniauth_providers.any? && session["omniauth.provider"].present? %>
    <!-- Removing password fields because you are connected with SSO and you don't have yet a password -->
    <%= f.hidden_field :omniauth_provider, value: session["omniauth.provider"] %>